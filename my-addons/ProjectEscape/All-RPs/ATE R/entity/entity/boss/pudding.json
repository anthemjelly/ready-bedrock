{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "ate:pudding",
      "min_engine_version": "1.8.0",
      "materials": {
        "default": "vindicator"
      },
      "textures": {
        "default": "textures/entity/ateentity/pudding"
      },
      "geometry": {
        "default": "geometry.ate_pudding"
      },
      "spawn_egg": {
        "base_color": "#FFFEFD",
        "overlay_color": "#FF0909"
      },
      "scripts": {
        "scale": "0.9375",
        "animate": [
          "vindicator_base",
          {"vindicator_walk":"query.ground_speed>0.02 && !query.is_riding"},
          "controller_look_at_target",
          "controller_vindicator_base",
          "controller_riding",
          {"bursting_clothes":"query.health<12"}
        ],
        "pre_animation": [
        "variable.has_target=query.has_target;"]
      },
      "animations": {
        "look_at_target_default": "animation.humanoid.look_at_target.default",
        "look_at_target_gliding": "animation.humanoid.look_at_target.gliding",
        "look_at_target_swimming": "animation.humanoid.look_at_target.swimming",
        "riding.arms": "animation.ate_pudding.riding.arms",
        "riding.legs": "animation.ate_pudding.riding.legs",
        "vindicator_base": "animation.ate_pudding.base",
        "vindicator_attack": "animation.ate_pudding.attack",
        "vindicator_walk": "animation.ate_pudding.walk",
        "celebrating": "animation.humanoid.celebrating",
        "controller_look_at_target": "controller.animation.humanoid.look_at_target",
        "controller_vindicator_base": "controller.animation.ate_pudding.base",
        "controller_riding": "controller.animation.humanoid.riding",
        "bursting_clothes":"animation.ate_pudding.bursting_clothes"
      },
      "render_controllers": [
        "controller.render.vindicator"
      ],
      "enable_attachables": true,
      "hide_armor": true
    }
  }
}