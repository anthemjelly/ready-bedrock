{
    "format_version": "1.10.0",
    "minecraft:client_entity": {
        "description": {
            "identifier": "ate:npc7",
            "materials": {
                "default": "skeleton"
            },
            "textures": {
                "default": "textures/entity/npc/yui"
            },
            "geometry": {
                "default": "geometry.yui"
            },
            "render_controllers": [
                "controller.render.default"
            ],
            "spawn_egg": {
                "base_color": "#505152",
                "overlay_color": "#3b9dff"
            },
            "scripts": {
                "scale": "0.88",
                "animate": [
                    "idle",
                    "look_at_player"
                ],
                "pre_animation": [
                    "v.a=query.bone_orientation_trs('head');"
                ]
            },
            "animations": {
                "idle": "animation.npc2.idle",
                "look_at_player": "animation.common.look_at_target"
            }
        }
    }
}