{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.ads": {
			"states": {
				"default": {
					"transitions": [
						{"ads": "q.is_sneaking"}
					],
					"blend_transition": 0.1
				},
				"ads": {
					"animations": ["aim"],
					"transitions": [
						{"default": "!q.is_sneaking"}
					],
					"blend_transition": 0.1
				}
			}
		},
		"controller.animation.gun": {
			"initial_state": "1st",
			"states": {
				"1st": {
					"animations": ["equip"],
					"transitions": [
						{"default": "1"}
					],
					"blend_transition": 0.3
				},
				"default": {
					"transitions": [
						{"full": "q.property('ate:gun') == 4 && q.is_using_item "},
						{"mid": "q.property('ate:gun') == 3 && q.is_using_item"}
					],
					"blend_transition": 0.1
				},
				"full": {
					"transitions": [
						{"fire": "q.is_using_item "}
					],
					"blend_transition": 0.1
				},
				"fire": {
					"animations": ["fire"],
					"transitions": [
						{"full": "!q.is_using_item"},
						{"default": "q.property('ate:gun') == 3"}
					],
					"blend_transition": 0.1
				},
				"mid": {
					"transitions": [
						{"mid2": "q.is_using_item"}
					],
					"blend_transition": 0.1
				},
				"mid2": {
					"transitions": [
						{"empty": "!q.is_using_item"}
					],
					"blend_transition": 0.1
				},
				"empty": {
					"transitions": [
						{"reload": "q.is_using_item"}
					],
					"blend_transition": 0.1
				},
				"reload": {
					"animations": ["reloading"],
					"transitions": [
						{"full": "q.property('ate:gun') == 4"},
						{"empty": "q.property('ate:gun') == 3 && q.all_animations_finished"}
					],
					"blend_transition": 0.1
				}
			}
		},
		"controller.animation.semigun": {
			"initial_state": "1st",
			"states": {
				"1st": {
					"animations": ["equip"],
					"transitions": [
						{"default": "1"}
					],
					"blend_transition": 0.3
				},
				"default": {
					"transitions": [
						{"full": "q.property('ate:gun') == 4 && q.is_using_item "},
						{"mid": "q.property('ate:gun') == 3 && q.is_using_item "}
					],
					"blend_transition": 0.1
				},
				"full": {
					"transitions": [
						{"fire": "q.is_using_item "}
					],
					"blend_transition": 0.1
				},
				"fire": {
					"animations": ["fire"],
					"transitions": [
						{"full": "q.all_animations_finished && !q.is_using_item"},
						{"default": "q.property('ate:gun') == 3"}
					],
					"blend_transition": 0.1
				},
				"mid": {
					"transitions": [
						{"mid2": "q.is_using_item"}
					],
					"blend_transition": 0.1
				},
				"mid2": {
					"transitions": [
						{"empty": "!q.is_using_item"}
					],
					"blend_transition": 0.1
				},
				"empty": {
					"transitions": [
						{"reload": "q.is_using_item"}
					],
					"blend_transition": 0.1
				},
				"reload": {
					"animations": ["reloading"],
					"transitions": [
						{"full": "q.property('ate:gun') == 4"},
						{"empty": "q.property('ate:gun') == 3&& q.all_animations_finished"}
					],
					"blend_transition": 0.1
				}
			}
		},
		"controller.animation.run": {
			"states": {
				"default": {
					"transitions": [
						{"run": "q.is_sprinting"}
					],
					"blend_transition": 0.1
				},
				"run": {
					"animations": ["sprint"],
					"transitions": [
						{"default": "!q.is_sprinting"}
					],
					"blend_transition": 0.1
				}
			}
		}
	}
}