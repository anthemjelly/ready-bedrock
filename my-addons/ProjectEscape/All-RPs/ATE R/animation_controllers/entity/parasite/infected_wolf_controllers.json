{
	"format_version" : "1.10.0",
	"animation_controllers" : {
		"controller.animation.infected_wolf.move" : {
			"initial_state" : "default",
			"states" : {
				"default" : {
					"animations" : [
						{
							"infected_wolf_move" : "query.ground_speed > 0.1 && !query.has_target"
						},
						{
							"infected_wolf_run" : "query.ground_speed > 0.1 && query.has_target"
						},
						{
"infected_wolf_static" : "query.ground_speed == 0"
						}
					]
				}
			}
		}
	}
}
