{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.ate_ice.base": {
			"states": {
				"default": {
					"transitions": [
						{"melee_attack": "query.is_item_equipped && variable.has_target && variable.attack_time >= 0.0"}
					],
					"blend_transition": 0.2
				},
				"melee_attack": {
					"animations": ["vindicator_attack"],
					"transitions": [
						{"default": "!query.is_item_equipped || !variable.has_target || variable.attack_time < 0.0 "}
					],
					"blend_transition": 0.2
				}
			}
		},
		"controller.animation.vindicator.base.v1.0": {
			"states": {
				"default": {
					"animations": ["vindicator_base", "vindicator_attack", "vindicator_walk"]
				}
			}
		}
	}
}