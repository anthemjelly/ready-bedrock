{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.ate_sheilr.basic": {
			"states": {
				"default": {
					"animations": ["vindicator_base"],
					"transitions": [
						{"attack": "query.is_item_equipped && variable.has_target && variable.attack_time >= 0.0"}
					],
					"blend_transition": 0.2
				},
				"attack": {
					"animations": ["vindicator_attack"],
					"transitions": [
						{"default": "!query.is_item_equipped || !variable.has_target || variable.attack_time < 0.0"}
					],
					"blend_transition": 0.1
				}
			}
		}
	}
}