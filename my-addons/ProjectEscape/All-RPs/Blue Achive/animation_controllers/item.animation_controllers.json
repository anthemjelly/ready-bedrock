{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.figure": {
            "initial_state": "idle",
            "states": {
                "idle": {
                    "animations": [],
                    "transitions": [
                        {
                            "fire": "query.is_using_item"
                        }
                    ],
                    "blend_transition": 0.1
                },
                "fire": {
                    "animations": [
                        "fire"
                    ],
                    "transitions": [
                        {
                            "idle": "query.all_animations_finished"
                        }
                    ],
                    "blend_transition": 0.2
                }
            }
        }
    }
}